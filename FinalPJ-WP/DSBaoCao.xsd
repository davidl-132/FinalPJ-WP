                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT  sp.TenGame,
        k.SoLuongTon,
        k.SoLuongToiThieu,
        k.NgayCapNhat,
        CASE
            WHEN k.SoLuongTon = 0 THEN N'Hết hàng'
            ELSE N'Sắp hết'
        END AS TinhTrangKho
FROM    Kho k
JOIN    SanPham sp ON sp.MaSanPham = k.MaSanPham
WHERE   k.SoLuongTon &lt;= k.SoLuongToiThieu
  AND   k.SoLuongToiThieu &gt; 0
ORDER BY k.SoLuongTon ASC</CommandText>
                    <Parameters />
                  </DbCommand>
