                      <PaddingTop>6pt</PaddingTop><PaddingBottom>6pt</PaddingBottom></Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="Hdr2"><CanGrow>true</CanGrow>
                    <Paragraphs><Paragraph><TextRuns><TextRun>
                      <Value>DOANH THU (VND)</Value>
                      <Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#1a3a5c</Color></Style>
                    </TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
