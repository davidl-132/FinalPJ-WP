        <Left>5in</Left><Top>0.35in</Top><Width>2.5in</Width><Height>0.22in</Height>
      </Textbox>

      <!-- BẢNG -->
      <Tablix Name="Tablix1">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>2.5in</Width></TablixColumn>
            <TablixColumn><Width>2.5in</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>

            <!-- HEADER ROW -->
            <TablixRow>
              <Height>0.28in</Height>
              <TablixCells>
                <TablixCell><CellContents>
                  <Textbox Name="Hdr1"><CanGrow>true</CanGrow>
                    <Paragraphs><Paragraph><TextRuns><TextRun>
                      <Value>SỐ ĐƠN HÀNG</Value>
                      <Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#1a3a5c</Color></Style>
                    </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                    <Style><BackgroundColor>#dde6f0</BackgroundColor><Border><Style>None</Style></Border>
