                </CellContents></TablixCell>
              </TablixCells>
            </TablixRow>

            <!-- DETAILS ROW -->
            <TablixRow>
              <Height>0.26in</Height>
              <TablixCells>
                <TablixCell><CellContents>
                  <Textbox Name="SoDonHang"><CanGrow>true</CanGrow>
                    <Paragraphs><Paragraph><TextRuns><TextRun>
                      <Value>=Sum(Fields!SoDonHang.Value)</Value>
                      <Style><FontFamily>Segoe UI</FontFamily><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>#1a3a5c</Color></Style>
                    </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0,"#f0f4f8","White")</BackgroundColor>
                      <Border><Style>None</Style></Border>
                      <BottomBorder><Color>#e2e8f0</Color><Style>Solid</Style><Width>0.5pt</Width></BottomBorder>
                      <PaddingTop>5pt</PaddingTop><PaddingBottom>5pt</PaddingBottom>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="DoanhThu"><CanGrow>true</CanGrow>
                    <Paragraphs><Paragraph><TextRuns><TextRun>
                      <Value>=Format(Sum(Fields!DoanhThu.Value), "#,##0")</Value>
                      <Style><FontFamily>Segoe UI</FontFamily><FontSize>10pt</FontSize><Color>#2d3748</Color></Style>
                    </TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0,"#f0f4f8","White")</BackgroundColor>
                      <Border><Style>None</Style></Border>
                      <BottomBorder><Color>#e2e8f0</Color><Style>Solid</Style><Width>0.5pt</Width></BottomBorder>
                      <PaddingRight>8pt</PaddingRight><PaddingTop>5pt</PaddingTop><PaddingBottom>5pt</PaddingBottom>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>
              </TablixCells>
            </TablixRow>

            <!-- FOOTER ROW -->
            <TablixRow>
              <Height>0.28in</Height>
