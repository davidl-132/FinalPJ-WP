          <PaddingLeft>12pt</PaddingLeft><PaddingRight>12pt</PaddingRight>
          <PaddingTop>10pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
        </Style>
        <Left>0in</Left><Top>0in</Top>
        <Width>7.5in</Width><Height>0.35in</Height>
      </Textbox>

      <Textbox Name="SubTitle">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Thống kê doanh thu và số đơn hàng theo từng tháng</Value>
                <Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><Color>#a8c4e0</Color></Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Left</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Style>
          <BackgroundColor>#1a3a5c</BackgroundColor>
          <Border><Style>None</Style></Border>
          <PaddingLeft>12pt</PaddingLeft><PaddingTop>0pt</PaddingTop><PaddingBottom>8pt</PaddingBottom>
        </Style>
        <Left>0in</Left><Top>0.35in</Top><Width>5in</Width><Height>0.22in</Height>
      </Textbox>

      <Textbox Name="NgayIn">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=("Ngày in: " &amp; Format(Now(), "dd/MM/yyyy"))</Value>
                <Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><Color>#a8c4e0</Color></Style>
