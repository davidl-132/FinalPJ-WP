      <!-- BẢNG -->
      <Tablix Name="Tablix1">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>1.6in</Width></TablixColumn>
            <TablixColumn><Width>1.6in</Width></TablixColumn>
            <TablixColumn><Width>1.8in</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>

            <!-- HEADER ROW -->
            <TablixRow>
              <Height>0.28in</Height>
              <TablixCells>
                <TablixCell><CellContents>
