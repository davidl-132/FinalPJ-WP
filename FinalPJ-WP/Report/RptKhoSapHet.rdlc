        </Style>
        <Left>0in</Left><Top>0.35in</Top><Width>5in</Width><Height>0.22in</Height>
      </Textbox>

      <Textbox Name="NgayIn">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=("Ngày in: " &amp; Format(Now(), "dd/MM/yyyy"))</Value>
